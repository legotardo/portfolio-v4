---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title: string;
	description?: string;
	keywords?: string[];
	author?: string;
	image?: string | ImageMetadata;
	needsEmail?: boolean;
}

const { title, description, keywords, author, image, needsEmail } = Astro.props;

function formatImageForMeta(): string | undefined {
	if (!image) return undefined;
	if (typeof image === "string") return image;

	return image.src;
}
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />

		<meta name="description" content={description} />
		<meta name="keywords" content={keywords?.join(", ")} />
		<meta name="author" content={author} />

		<meta name="og:title" content={title} />
		<meta name="og:image" content={formatImageForMeta()} />
		<meta property="og:type" content="website" />
		<meta name="og:description" content={description} />

		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/ico" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap"
			rel="stylesheet"
		/>
		{
			needsEmail && (
				<script
					is:inline
					defer
					type="text/javascript"
					src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"
				/>
			)
		}
		<title>{title}</title>
		<script>
			import { initTheme } from "../helpers/theme";

			initTheme();
		</script>
	</head>
	<body>
		<Navbar />
		<slot />
		<Footer />
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400..700&display=swap');

	:root {
		--navbar-height: 5rem;
	}

	::-webkit-scrollbar {
		width: 6px;
		height: 6px;
	}

	::-webkit-scrollbar-thumb {
		background: rgba(255, 255, 255, 0.4);
		border-radius: 10px;
	}

	::-webkit-scrollbar-track {
		background: transparent;
		border-radius: 10px;
	}

	::selection {
		@apply bg-purple-600 text-white;
		@apply win95:bg-win95-primary;
	}

	::-moz-selection {
		@apply bg-purple-600 text-white;
		@apply win95:bg-win95-primary;
	}

	html {
		scroll-behavior: smooth;
	}

	.pixel-font {
		font-family: "Pixelify Sans", monospace, sans-serif !important;
		-webkit-font-smoothing: none; /* Safari/Chrome */
		-moz-osx-font-smoothing: auto; /* Firefox */
		text-rendering: geometricPrecision !important;
		text-shadow: none !important;
		font-weight: normal !important;
	}

	body {
		@apply bg-black text-white overflow-x-hidden;
		@apply win95:bg-win95-windowsBackground;
	}

	* {
		@apply win95:!pixel-font;
	}

	.default-container-size {
		@apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
	}

	.article-size {
		@apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
	}

	.default-card {
		@apply bg-gray-700/20 border border-gray-600 rounded-xl shadow-md backdrop-blur;
	}

	.markdown-prettier {
		@apply flex flex-col gap-6 text-slate-200;
	}

	.markdown-prettier h1 {
		@apply text-4xl font-bold;
	}

	.markdown-prettier h2 {
		@apply text-3xl font-bold;
	}

	.markdown-prettier h3 {
		@apply text-2xl font-semibold text-slate-200;
	}

	.markdown-prettier h4 {
		@apply text-xl font-semibold text-slate-200;
	}

	.markdown-prettier img {
		@apply rounded-lg;
	}

	.markdown-prettier pre {
		@apply p-4 rounded-xl;
	}

	.markdown-prettier li {
		@apply list-disc list-inside;
	}

	.markdown-prettier li:not(:first-child) {
		@apply mt-3;
	}

	.markdown-prettier table {
		@apply w-fit overflow-hidden;
	}

	.markdown-prettier table th,
	.markdown-prettier table td {
		@apply border border-slate-600;
	}

	.markdown-prettier table img {
		@apply w-fit max-h-[500px] object-contain rounded-none;
	}

	.markdown-prettier a {
		@apply underline text-purple-400 hover:text-purple-500;
	}

	.win95-card {
		@apply win95:bg-win95-appBackground win95:rounded-none win95:border-win95-appBorder win95:border-3 win95:backdrop-blur-none;
	}
</style>
