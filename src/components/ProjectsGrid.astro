---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { formatDate } from "../helpers/date";
import Tag from "./Tag.vue";

const allProjects = await getCollection("projects");

interface Props {
    class?: string;
    limit?: number;
}

const { limit, ...attrs } = Astro.props;
---

<div id="projects-grid" class:list={["projects grid gap-4", attrs.class]}>
    {
        allProjects
            .sort((a, b) => {
                return (
                    new Date(b.data.createdAt).getTime() -
                    new Date(a.data.createdAt).getTime()
                );
            })
            .slice(0, limit ?? allProjects.length)
            .map((project) => (
                <a
                    href={`/projects/${project.id}`}
                    id="project-card"
                    class="h-fit"
                >
                    <div class="default-card flex flex-col rounded-2xl group cursor-pointer
                                win95-card">
                        <Image
                            style={{ aspectRatio: "1.78" }}
                            src={project.data.cover}
                            alt={project.data.title}
                            widths={[500]}
                            class="project-image group-hover:-translate-y-2 win95:group-hover:-translate-y-0 rounded-t-xl win95:rounded-none"
                            loading="eager"
                        />
                        <div class="p-4">
                            <h1 class="font-bold group-hover:text-purple-500 transition
                                       win95:text-black win95:group-hover:text-win95-buttonText win95:group-hover:underline">
                                {project.data.title}
                            </h1>
                            <span class="text-xs win95:text-win95-textSecondary">
                                {formatDate(project.data.createdAt)}
                            </span>
                            <div class="flex gap-1 mt-1">
                                {project.data.tags.map((tag) => (
                                    <Tag>{tag}</Tag>
                                ))}
                            </div>
                        </div>
                    </div>
                </a>
            ))
    }
</div>

<script>
    import { animate, stagger, inView } from "motion";

    inView("#projects-grid", () => {
        animate(
            "#project-card",
            { opacity: [0, 1], y: [-20, 0] },
            { delay: stagger(0.05) },
        );
    });
</script>

<style>
    .projects {
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    .project-image {
        transition: cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.5s;
    }

    #project-card {
        opacity: 0;
    }
</style>
