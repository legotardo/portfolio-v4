---
import { Image } from "astro:assets";

import spotifyWEBP from "../../assets/images/spotify.webp";
import codeWEBP from "../../assets/images/code.webp";
import githubWEBP from "../../assets/images/github.webp";

import Spotify from "./kinds/Spotify.vue";
import Github from "./kinds/Github.vue";
import Wakatime from "./kinds/Wakatime.vue";

const APIS = [
    {
        icon: spotifyWEBP,
        color: "#000000",
        caption: "last played song",
        alt: "spotify logo",
        componentName: "Spotify",
    },
    {
        icon: githubWEBP,
        title: "My Github Profile",
        color: "#FFFFFF",
        componentName: "Github",
    },
    {
        icon: codeWEBP,
        title: "Code Status",
        color: "#FFFFFF",
        caption: "last month (first 5 languages)",
        componentName: "Wakatime",
    },
];

interface Props {
    id?: string;
}

const { id } = Astro.props;
---

<section
    class="h-fit p-4 default-card flex flex-col gap-4 backdrop-blur
         win95-card"
    id={id}
>
    {
        APIS.map((api) => (
            <div class="flex items-center gap-4 bg-gray-500/10 border border-transparent rounded-xl p-4 relative backdrop-blur transition-all hover:cursor-pointer hover:bg-purple-600/10 hover:border-purple-600
                        win95:bg-transparent win95:border-win95-buttonBorder win95:rounded-none win95:hover:bg-win95-buttonFaceActive"
                data-spotify-card={api.componentName === "Spotify" ? "true" : undefined}
            >
                <Image
                    src={api.icon}
                    alt={api.title ?? api.alt}
                    style={{ backgroundColor: api.color }}
                    class="w-20 h-20 rounded-xl p-3 transition-opacity duration-200 ease-out win95:rounded-none win95:border-win95-buttonFace win95:border-2"
                    data-spotify-icon={api.componentName === "Spotify" ? "true" : undefined}
                />
                <div class="w-full overflow-hidden">
                    {api.title && (
                        <h2 class="text-base uppercase win95:text-black">{api.title}</h2>
                    )}
                    {api.componentName === "Spotify" && <Spotify client:load />}
                    {api.componentName === "Github" && <Github client:load />}
                    {api.componentName === "Wakatime" && (
                        <Wakatime client:load />
                    )}
                </div>
                <span
                    v-if="api.caption"
                    class="absolute hidden sm:block top-2 right-3 text-xs text-gray-400
                           win95:text-black win95:hidden"
                >
                    {api.caption}
                </span>
            </div>
        ))
    }
</section>

<script>
    async function setupSpotifyHoverIcon() {
        const spotifyCards = document.querySelectorAll('[data-spotify-card="true"]');
        if (!spotifyCards.length) return;

        let hoverImageUrl = "";
        const swapTimers = new WeakMap<HTMLImageElement, number>();

        function swapIconWithFade(icon: HTMLImageElement, nextSrc: string, coverMode: boolean) {
            const existingTimer = swapTimers.get(icon);
            if (typeof existingTimer === "number") {
                window.clearTimeout(existingTimer);
            }

            icon.classList.add("opacity-40");

            const timer = window.setTimeout(() => {
                icon.src = nextSrc;

                if (coverMode) {
                    icon.classList.remove("p-3");
                    icon.classList.add("p-0", "object-cover");
                } else {
                    icon.classList.remove("p-0", "object-cover");
                    icon.classList.add("p-3");
                }

                icon.classList.remove("opacity-40");
                swapTimers.delete(icon);
            }, 110);

            swapTimers.set(icon, timer);
        }

        window.addEventListener("spotify-track-change", (event) => {
            if (!(event instanceof CustomEvent)) return;
            const image = event.detail?.image;
            if (typeof image !== "string" || !image) return;

            hoverImageUrl = image;
            const preloadImage = new window.Image();
            preloadImage.src = hoverImageUrl;
        });

        spotifyCards.forEach((card) => {
            const icon = card.querySelector('[data-spotify-icon="true"]');
            if (!(icon instanceof HTMLImageElement)) return;

            const originalSrc = icon.currentSrc || icon.src;

            card.addEventListener("mouseenter", () => {
                if (!hoverImageUrl) return;
                swapIconWithFade(icon, hoverImageUrl, true);
            });

            card.addEventListener("mouseleave", () => {
                swapIconWithFade(icon, originalSrc, false);
            });
        });
    }

    setupSpotifyHoverIcon();
</script>
